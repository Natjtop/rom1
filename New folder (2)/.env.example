# ─────────────────────────────────────────────────────────────
# Replyma Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Generate secrets: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────

# ─── Ports (change if conflicting with existing services) ───
POSTGRES_PORT=5433
REDIS_PORT=6380
SOKETI_PORT=6002
BACKEND_PORT=4000
FRONTEND_PORT=3001

# ─── Database ───
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Security (REQUIRED) ───
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ─── Domain / URLs ───
FRONTEND_URL=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# ─── WebSocket (Soketi) ───
NEXT_PUBLIC_PUSHER_KEY=replyma-key
NEXT_PUBLIC_PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_HOST=ws.yourdomain.com
NEXT_PUBLIC_PUSHER_PORT=443
PUSHER_APP_ID=replyma-app
PUSHER_KEY=replyma-key
PUSHER_SECRET=replyma-secret

# ─── Shopify (optional) ───
NEXT_PUBLIC_SHOPIFY_API_KEY=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ─── AWS (SES email + Bedrock AI + S3 uploads) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=replyma-uploads
AWS_SES_FROM_EMAIL=support@yourdomain.com
AWS_SES_INBOUND_DOMAIN=yourdomain.com

# ─── Google OAuth (optional) ───
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Stripe (billing) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
